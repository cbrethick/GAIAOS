# GaiaOS Environment Variables (Example)
# Replace placeholders with your actual API keys/credentials.

# --- Data Sources (Climate & Environmental) ---

# Copernicus Marine Service / Climate Data Store (ERA5, Sentinel)
# Get credentials at: https://cds.climate.copernicus.eu
COPERNICUS_CDS_API_URL=https://cds.climate.copernicus.eu/api/v2
COPERNICUS_CDS_API_KEY=your_api_key_here

# NASA Earthdata (SMAP, MODIS, FIRMS, SRTM)
# Get credentials at: https://urs.earthdata.nasa.gov
NASA_EARTHDATA_USER=your_username
NASA_EARTHDATA_PASS=your_password

# OpenStreetMap / Overpass API
# Usually free, but some providers require keys for higher limits
OSM_API_KEY=optional_key_here

# --- Backend Configuration ---

PORT=4000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/gaiaos

# --- Frontend Configuration ---

VITE_API_BASE_URL=http://localhost:4000/api
